# VoiceClaw 环境变量配置
# 复制此文件为 .env 并填入真实值

# ── 火山云 RTC ──────────────────────────────────────
RTC_APP_ID=你的_RTC_AppID
RTC_APP_KEY=你的_RTC_AppKey
RTC_ROOM_ID=voiceclaw-main
RTC_USER_ID=server

# ── 豆包语音识别 2.0（方舟平台）────────────
ASR_API_KEY=你的_方舟_API_Key
ASR_APP_ID=你的_ASR_AppID
ASR_CLUSTER=volcengine_streaming_common

# ── 豆包语音合成 2.0（方舟平台）────────────
TTS_API_KEY=你的_方舟_API_Key
TTS_APP_ID=你的_TTS_AppID
TTS_VOICE_TYPE=BV700_V2_streaming
TTS_CLUSTER=volcano_tts

# ── 龙虾 Gateway ────────────────────────────────────
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=你的_Gateway_Token

# ── Mock 开关（阶段一用）────────────────────────────
USE_MOCK_GATEWAY=true
MOCK_GATEWAY_PORT=19001
